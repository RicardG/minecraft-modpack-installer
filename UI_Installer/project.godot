; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "PanelContainer",
"class": "FooterPane",
"language": "GDScript",
"path": "res://Objects/NextTabFooter.gd"
}, {
"base": "Control",
"class": "ModulePane",
"language": "GDScript",
"path": "res://Scripts/CustomUI/ModulePane.gd"
}, {
"base": "ModulePane",
"class": "StepController",
"language": "GDScript",
"path": "res://Objects/StepController.gd"
} ]
_global_script_class_icons={
"FooterPane": "",
"ModulePane": "",
"StepController": ""
}

[application]

config/name="Ui Installer"
run/main_scene="res://Objects/InstallerWindow.tscn"
run/low_processor_mode=true
run/low_processor_mode_sleep_usec=10000
config/icon="res://icon.png"

[autoload]

Global="*res://Scripts/Global.gd"

[physics]

common/enable_pause_aware_picking=true

[rendering]

environment/default_environment="res://default_env.tres"
